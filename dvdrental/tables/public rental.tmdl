	column last_update
		dataType: dateTime
		formatString: General Date
		lineageTag: 9fcbbb15-3a18-4edc-ba0f-1ea20b205089
		summarizeBy: none
		sourceColumn: last_update

		variation Variation
			isDefault
			relationship: e0af8162-3ec3-430a-afd6-9a5e378ac7d8
			defaultHierarchy: LocalDateTable_8b069438-6a9e-4458-971f-2a42f025dd6f.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column 'Rental Month' = FORMAT('public rental'[rental_date], "YYYY-MM")
		dataType: string
		lineageTag: 449b528c-e2be-44cf-8ec6-231ab26f110e

	column 'Rental Duration Days' = DATEDIFF('public rental'[rental_date], 'public rental'[return_date], DAY)
		dataType: int64
		lineageTag: 365edbb2-97fb-49c6-92a0-c9d7de65f530

	column 'Rental Status' = IF(ISBLANK('public rental'[return_date]), "Out", "Returned")
		dataType: string
		lineageTag: 1628400b-7007-4da2-9292-2f18fa08c414

	partition 'public rental' = m
		mode: import
		source =
				let
				    Source = PostgreSQL.Database("localhost", "dvdrental"),
				    public_rental = Source{[Schema="public",Item="rental"]}[Data]
				in
				    public_rental

	annotation PBI_ResultType = Table

